<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy to GoogleService-Info.plist after adding an iOS app in Firebase Console.

  Firebase project: mega-e-business-card
  Bundle ID (must match): com.megaannumai.ebusinesscard

  Firebase Console → Project settings → Your apps → Add iOS app → download plist
  Place at: ios/GoogleService-Info.plist
  Then add the file to the EBusinessCard target in Xcode (drag into project navigator).
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>359348506633</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.megaannumai.ebusinesscard</string>
	<key>PROJECT_ID</key>
	<string>mega-e-business-card</string>
	<key>STORAGE_BUCKET</key>
	<string>mega-e-business-card.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:359348506633:ios:YOUR_IOS_APP_ID</string>
</dict>
</plist>
